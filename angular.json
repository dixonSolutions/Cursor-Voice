{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "cursor-voice-web": {
      "projectType": "application",
      "root": "web",
      "sourceRoot": "web/src",
      "prefix": "cv",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "web/dist",
              "browser": ""
            },
            "index": "web/src/index.html",
            "browser": "web/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "web/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "web/public"
              }
            ],
            "styles": [
              "web/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "900kB",
                  "maximumError": "2MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "8kB",
                  "maximumError": "16kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "outputHashing": "none"
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "cursor-voice-web:build:production"
            },
            "development": {
              "buildTarget": "cursor-voice-web:build:development"
            }
          },
          "options": {
            "proxyConfig": "web/proxy.conf.json",
            "port": 4200
          },
          "defaultConfiguration": "development"
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
