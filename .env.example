# Cursor Voice — Environment Variables
# Copy to .env, fill in values. Keep .env chmod 600. NEVER commit it.
# Secrets and machine-specific paths only. Everything else belongs in config.json.

# ── Secrets ──────────────────────────────────────────────────────────────────
APP_TOKEN=                      # high-entropy shared secret
                                # generate: openssl rand -base64 32

OPENAI_API_KEY=                 # speech provider key (NOT your Cursor account)
# GEMINI_API_KEY=               # uncomment if VOICE_PROVIDER=gemini in config.json

# ── Bootstrap paths / bind (non-secret but machine-specific) ─────────────────
PORT=8787
CONFIG_PATH=./config.json
DB_PATH=./data/state.db
