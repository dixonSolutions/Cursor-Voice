# Cursor Voice — Environment Variables
# Copy to .env, fill in values. Keep .env chmod 600. NEVER commit it.
# Secrets and machine-specific paths only. Voice preferences live in config.json.

# ── App auth ─────────────────────────────────────────────────────────────────
APP_TOKEN=                      # high-entropy shared secret
                                # generate: openssl rand -base64 32

# ── Voice provider keys (set only what you use — viability is auto-detected) ─
OPENAI_API_KEY=                 # OpenAI Realtime
# GEMINI_API_KEY=               # Google Gemini Live
# ANTHROPIC_API_KEY=            # Anthropic Claude voice
# AWS_ACCESS_KEY_ID=            # Amazon Bedrock (key name from console)
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1          # optional; defaults to us-east-1

# ── Web Push (PWA background notifications) ─────────────────────────────────
# Generate: bash scripts/gen-vapid-keys.sh
# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=
# WEB_PUSH_VAPID_SUBJECT=mailto:you@example.com

# ── Apple Push (native iOS app — optional until TestFlight build) ───────────
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_KEY_PATH=./AuthKey_XXXXX.p8
# APNS_BUNDLE_ID=com.cursorvoice.app
# APNS_PRODUCTION=false

# ── Bootstrap paths / bind (non-secret but machine-specific) ─────────────────
PORT=8787
CONFIG_PATH=./config.json
DB_PATH=./data/state.db
