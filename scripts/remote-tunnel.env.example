# Cursor Voice — SSH tunnel for split-host hosting
#
# Copy to ~/.config/cursor-voice/tunnel.env and edit.
# Used by scripts/ssh-remote-tunnel.sh and the cursor-voice-tunnel systemd user unit.
#
# Topology:
#   [Tailscale front door — this machine]  LOCAL_BIND_PORT
#        SSH -L →
#   [Remote host — nginx + bridge]        REMOTE_BIND_PORT

# SSH target (user@host or user@tailscale-ip)
REMOTE_SSH=borys@100.118.238.2

# Port on the remote host (nginx webPort in split-port setup)
REMOTE_BIND_HOST=127.0.0.1
REMOTE_BIND_PORT=5671

# Port on this machine (Tailscale serve upstream)
LOCAL_BIND_HOST=127.0.0.1
LOCAL_BIND_PORT=15671
