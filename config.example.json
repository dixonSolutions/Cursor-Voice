{
  "settings": {
    "runMode": "test",
    "runModes": {
      "test": {
        "backendPort": 3000,
        "webPort": 4200
      },
      "serve": {
        "backendPort": 8787,
        "publicBaseUrl": "https://your-machine.tailnet-name.ts.net"
      }
    },
    "workflow": {
      "default": "cursor_native",
      "llmIntelligence": {
        "llm": {
          "provider": "bedrock",
          "model": "us.anthropic.claude-sonnet-4-20250514-v1:0",
          "region": "us-east-1",
          "maxTokens": 4096
        },
        "systemPrompts": [
          "prompts/llm-intelligence/systemprompts.json"
        ],
        "memory": {
          "maxTurns": 10,
          "keepTurns": 4,
          "summarySentences": 3
        },
        "readOutputMaxChars": 8000,
        "audio": {
          "preferWebkit": true,
          "pollyVoiceId": "Joanna",
          "pollyEngine": "neural",
          "transcribeLanguageCode": "en-US"
        }
      },
      "s2sVoice": {
        "systemPrompts": [
          "prompts/systemprompts.json"
        ]
      }
    },
    "voice": {
      "defaultProvider": "openai",
      "providers": {
        "openai": {
          "defaultModel": "gpt-realtime-mini",
          "models": [
            {
              "id": "gpt-realtime-mini",
              "label": "GPT Realtime Mini",
              "builtin": true
            },
            {
              "id": "gpt-4o-mini-realtime-preview",
              "label": "GPT-4o Mini Realtime",
              "builtin": true
            },
            {
              "id": "gpt-realtime",
              "label": "GPT Realtime",
              "builtin": true
            },
            {
              "id": "gpt-4o-realtime-preview",
              "label": "GPT-4o Realtime Preview",
              "builtin": true
            }
          ]
        },
        "amazon_bedrock": {
          "defaultModel": "amazon.nova-2-sonic-v1:0",
          "models": [
            {
              "id": "amazon.nova-2-sonic-v1:0",
              "label": "Nova 2 Sonic",
              "builtin": true
            },
            {
              "id": "amazon.nova-sonic-v1:0",
              "label": "Nova Sonic v1",
              "builtin": true
            }
          ]
        },
        "gemini": {
          "defaultModel": "gemini-2.5-flash-native-audio-preview-12-2025",
          "models": [
            {
              "id": "gemini-2.5-flash-native-audio-preview-12-2025",
              "label": "Gemini 2.5 Flash Live",
              "builtin": true
            },
            {
              "id": "gemini-2.0-flash-live-preview",
              "label": "Gemini 2.0 Flash Live",
              "builtin": true
            }
          ]
        }
      },
      "wakeWords": {
        "start": "cursor listen",
        "end": "cursor send"
      },
      "turnSubmit": {
        "silenceMs": 1500,
        "vadEnabled": true
      },
      "systemPrompts": [
        "prompts/systemprompts.json"
      ]
    },
    "defaultMode": "agent",
    "maxConcurrentJobs": 1,
    "jobTimeoutMs": 600000,
    "planFirst": false,
    "preRunFlags": [
      "--force",
      "--trust"
    ],
    "modelCacheTtlMs": 3600000,
    "narratorEnabled": true,
    "narratorCadenceMs": 15000,
    "narratorMaxBufferEvents": 50,
    "ghostKillEnabled": true,
    "logLevel": "info"
  },
  "projects": [
    {
      "name": "cursorvoice",
      "path": "/home/eva/Projects/SideProjects/CursorVoice",
      "aliases": [
        "cursor voice",
        "the voice project"
      ],
      "description": "This project — the voice bridge",
      "enabled": true
    },
    {
      "name": "budget",
      "path": "/home/projects/budget-app",
      "aliases": [
        "budget app",
        "the finance tracker",
        "money app"
      ],
      "description": "Personal finance tracker (web)",
      "enabled": true
    }
  ]
}
