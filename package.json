{
  "name": "cursor-voice",
  "version": "0.1.0",
  "description": "Self-hosted voice bridge for cursor-agent",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup && npm run build:web",
    "build:bridge": "tsup",
    "build:web": "ng build cursor-voice-web",
    "dev": "tsx watch src/index.ts",
    "dev:web": "ng serve cursor-voice-web",
    "gen-icons": "node scripts/gen-icons.mjs",
    "lint": "eslint src web/src",
    "typecheck": "tsc --noEmit && npx tsc --noEmit -p web/tsconfig.app.json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@angular/animations": "^22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "@primeuix/themes": "^2.0.3",
    "better-sqlite3": "^12.0.0",
    "dotenv": "^16.0.0",
    "fastify": "^5.0.0",
    "pino": "^9.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.9",
    "simple-git": "^3.0.0",
    "strip-ansi": "^7.0.0",
    "zod": "^3.0.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@types/better-sqlite3": "^7.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "allowScripts": {
    "better-sqlite3@12.10.1": true,
    "esbuild@0.27.7": true,
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true
  }
}
