{
  "name": "cursor-voice",
  "version": "0.1.0",
  "description": "Self-hosted voice bridge for cursor-agent",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build:backend && npm run build:web",
    "build:backend": "tsup",
    "build:web": "ng build cursor-voice-web --configuration production",
    "dev": "NODE_ENV=development concurrently -n web,server -c cyan,magenta \"ng serve cursor-voice-web\" \"nodemon\"",
    "dev:web": "ng serve cursor-voice-web",
    "gen-icons": "node scripts/gen-icons.mjs",
    "prepare:vosk": "node scripts/download-vosk-model.mjs",
    "lint": "eslint src web/src",
    "typecheck": "tsc --noEmit && npx tsc --noEmit -p web/tsconfig.app.json",
    "start": "NODE_ENV=production node dist/index.js"
  },
  "dependencies": {
    "@angular/animations": "^22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@aws-sdk/client-bedrock-runtime": "^3.1068.0",
    "@aws-sdk/client-polly": "^3.1070.0",
    "@aws-sdk/client-sts": "^3.1068.0",
    "@aws-sdk/client-transcribe-streaming": "^3.1070.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@primeuix/themes": "^2.0.3",
    "@ricky0123/vad-web": "^0.0.30",
    "@smithy/node-http-handler": "^4.7.8",
    "better-sqlite3": "^12.0.0",
    "dotenv": "^16.0.0",
    "fastify": "^5.0.0",
    "pino": "^9.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.9",
    "simple-git": "^3.0.0",
    "strip-ansi": "^7.0.0",
    "vosk-browser": "^0.0.8",
    "zod": "^3.0.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@types/better-sqlite3": "^7.0.0",
    "@types/http-proxy": "^1.17.16",
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "http-proxy": "^1.18.1",
    "nodemon": "^3.1.11",
    "pino-pretty": "^11.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "allowScripts": {
    "better-sqlite3@12.10.1": true,
    "esbuild@0.27.7": true,
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true
  }
}
